---
/**
 * ParticleField — full-viewport flow field particle system.
 * Pure canvas 2D API, no external libraries.
 *
 * - Particles follow a vector field built from layered sin/cos (organic drift)
 * - Cursor creates a circular repulsion zone
 * - Particle count scales with viewport area (responsive / perf)
 * - Pauses when the tab is hidden (Page Visibility API)
 *
 * All tunable values live in CONFIG inside the script below.
 */
---

<canvas id="particle-field" aria-hidden="true"></canvas>

<style>
  #particle-field {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: var(--z-canvas);
    display: block;
  }
</style>

<script>
  // --- Tunables ----------------------------------------------------------
  const CONFIG = {
    color: "200, 230, 58", // --accent as RGB, alpha set per particle
    minRadius: 0.5,
    maxRadius: 2,
    maxSpeed: 0.8, // px per frame
    trailFade: 0.12, // lower = longer trails
    fieldScale: 0.0016, // spatial frequency of the flow field
    fieldSpeed: 0.0004, // how fast the field itself evolves over time
    repelRadius: 120, // px — cursor influence
    repelStrength: 1.1,
    // Particle density: one particle per N px of viewport area, clamped.
    areaPerParticle: 9000,
    minParticles: 60,
    maxParticles: 240,
  };

  const canvas = document.getElementById("particle-field") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d", { alpha: false })!;

  let width = 0;
  let height = 0;
  let dpr = 1;
  let particles: Particle[] = [];
  let rafId = 0;
  let running = false;

  const pointer = { x: -9999, y: -9999, active: false };

  type Particle = {
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    a: number; // alpha
  };

  function rand(min: number, max: number) {
    return min + Math.random() * (max - min);
  }

  function targetParticleCount() {
    const count = Math.round((width * height) / CONFIG.areaPerParticle);
    return Math.max(CONFIG.minParticles, Math.min(CONFIG.maxParticles, count));
  }

  function makeParticle(): Particle {
    return {
      x: Math.random() * width,
      y: Math.random() * height,
      vx: 0,
      vy: 0,
      r: rand(CONFIG.minRadius, CONFIG.maxRadius),
      a: rand(0.15, 0.7),
    };
  }

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = Math.floor(width * dpr);
    canvas.height = Math.floor(height * dpr);
    canvas.style.width = width + "px";
    canvas.style.height = height + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    // Paint a solid background once so trail-fade has something to blend over.
    ctx.fillStyle = "#0d0e08";
    ctx.fillRect(0, 0, width, height);

    // Re-pool particles to match the new viewport size.
    const target = targetParticleCount();
    if (particles.length < target) {
      while (particles.length < target) particles.push(makeParticle());
    } else if (particles.length > target) {
      particles.length = target;
    }
  }

  // Flow field angle at a point, evolving slowly over time.
  function fieldAngle(x: number, y: number, t: number) {
    const s = CONFIG.fieldScale;
    return (
      (Math.sin(x * s + t) + Math.cos(y * s - t) + Math.sin((x + y) * s * 0.5)) *
      Math.PI
    );
  }

  function step(time: number) {
    const t = time * CONFIG.fieldSpeed;

    // Semi-transparent fill instead of a hard clear → ghostly fading trails.
    ctx.fillStyle = `rgba(13, 14, 8, ${CONFIG.trailFade})`;
    ctx.fillRect(0, 0, width, height);

    for (const p of particles) {
      // Steer toward the flow field direction.
      const angle = fieldAngle(p.x, p.y, t);
      p.vx += Math.cos(angle) * 0.04;
      p.vy += Math.sin(angle) * 0.04;

      // Cursor repulsion.
      if (pointer.active) {
        const dx = p.x - pointer.x;
        const dy = p.y - pointer.y;
        const dist = Math.hypot(dx, dy);
        if (dist < CONFIG.repelRadius && dist > 0.001) {
          const force =
            ((CONFIG.repelRadius - dist) / CONFIG.repelRadius) *
            CONFIG.repelStrength;
          p.vx += (dx / dist) * force;
          p.vy += (dy / dist) * force;
        }
      }

      // Damping + speed clamp keeps motion slow and meditative.
      p.vx *= 0.96;
      p.vy *= 0.96;
      const speed = Math.hypot(p.vx, p.vy);
      if (speed > CONFIG.maxSpeed) {
        p.vx = (p.vx / speed) * CONFIG.maxSpeed;
        p.vy = (p.vy / speed) * CONFIG.maxSpeed;
      }

      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges for a seamless field.
      if (p.x < -5) p.x = width + 5;
      else if (p.x > width + 5) p.x = -5;
      if (p.y < -5) p.y = height + 5;
      else if (p.y > height + 5) p.y = -5;

      ctx.beginPath();
      ctx.fillStyle = `rgba(${CONFIG.color}, ${p.a})`;
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }

    rafId = requestAnimationFrame(step);
  }

  function start() {
    if (running) return;
    running = true;
    rafId = requestAnimationFrame(step);
  }

  function stop() {
    running = false;
    cancelAnimationFrame(rafId);
  }

  // --- Events ------------------------------------------------------------
  window.addEventListener("resize", resize);

  window.addEventListener("pointermove", (e) => {
    pointer.x = e.clientX;
    pointer.y = e.clientY;
    pointer.active = true;
  });
  window.addEventListener("pointerleave", () => {
    pointer.active = false;
  });

  // Pause in background tabs to save CPU.
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) stop();
    else start();
  });

  // --- Init --------------------------------------------------------------
  resize();
  start();
