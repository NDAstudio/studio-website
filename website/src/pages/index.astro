---
import "../styles/global.css";
import ShaderField from "../components/ShaderField.astro";
import GrainOverlay from "../components/GrainOverlay.astro";
import SiteName from "../components/SiteName.astro";
import ContactLinks from "../components/ContactLinks.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NDA/studio</title>
  </head>
  <body>
    <!-- background layers -->
    <ShaderField />
    <GrainOverlay />

    <!-- content -->
    <main class="page">
      <SiteName />
      <ContactLinks />
    </main>

    <style>
      .page {
        position: fixed;
        inset: 0;
        z-index: var(--z-content);
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* anchor to bottom */
        align-items: flex-start;
        gap: 1.5rem;
        padding: var(--page-padding);
      }
    </style>
  </body>
</html>
