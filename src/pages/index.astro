---
import "../styles/global.css";
import ShaderField from "../components/ShaderField.astro";
import GrainOverlay from "../components/GrainOverlay.astro";
import SiteName from "../components/SiteName.astro";
import ContactLinks from "../components/ContactLinks.astro";

// Base path ("/" on the custom domain) so font URLs resolve consistently.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NDA/studio</title>

    <style
      set:html={`
      @font-face {
        font-family: 'Picnic';
        src: url('${base}fonts/PicNic.woff2') format('woff2');
        font-display: swap;
      }
      @font-face {
        font-family: 'Karrik';
        src: url('${base}fonts/Karrik-Regular.woff2') format('woff2');
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Karrik';
        src: url('${base}fonts/Karrik-Italic.woff2') format('woff2');
        font-style: italic;
        font-display: swap;
      }
    `}
    />
  </head>
  <body>
    <!-- background layers -->
    <ShaderField />
    <GrainOverlay />

    <!-- content -->
    <main class="page">
      <SiteName />
      <ContactLinks />
    </main>

    <style>
      .page {
        position: fixed;
        inset: 0;
        z-index: var(--z-content);
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* anchor to bottom */
        align-items: flex-start;
        gap: 1.5rem;
        padding: var(--page-padding);
      }
    </style>
  </body>
</html>
