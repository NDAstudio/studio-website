---
/**
 * ContactLinks — email + socials inside a frosted-glass pill,
 * framed with lime corner-bracket accents (board style).
 * Links are driven entirely by site config.
 */
import { site } from "../config/site";
const { email, socials } = site;
---

<div class="contact-frame">
  <span class="bracket bracket--tl" aria-hidden="true"></span>
  <span class="bracket bracket--tr" aria-hidden="true"></span>
  <span class="bracket bracket--bl" aria-hidden="true"></span>
  <span class="bracket bracket--br" aria-hidden="true"></span>

  <nav class="contact" aria-label="Contact and social links">
    <a class="contact__link contact__email" href={`mailto:${email}`}>{email}</a>
    <ul class="contact__socials">
      {
        socials.map((s) => (
          <li>
            <a
              class="contact__link"
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              title={s.title}
              aria-label={s.title}
            >
              {s.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<style>
  .contact-frame {
    position: relative;
    align-self: flex-start;
    /* room for the corner brackets to sit just outside the pill */
    padding: 6px;
  }

  /* Frosted-glass pill */
  .contact {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.9rem 2rem;
    padding: 1.05rem 1.8rem;
    border-radius: 999px;
    background: rgba(245, 242, 230, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow: 0 4px 24px rgba(29, 43, 13, 0.1);
    backdrop-filter: blur(14px) saturate(1.2);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--muted);
  }

  .contact__socials {
    display: flex;
    gap: 1.75rem;
    list-style: none;
  }

  .contact__email {
    letter-spacing: 0.01em;
    font-size: 16px;
    color: var(--text);
  }

  .contact__link {
    color: var(--muted);
    transition: color 0.2s ease;
  }
  .contact__email {
    color: var(--text);
  }
  .contact__link:hover,
  .contact__link:focus-visible {
    color: var(--accent);
  }

  /* Corner brackets */
  .bracket {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--accent);
  }
  .bracket--tl {
    top: 0;
    left: 0;
    border-right: 0;
    border-bottom: 0;
  }
  .bracket--tr {
    top: 0;
    right: 0;
    border-left: 0;
    border-bottom: 0;
  }
  .bracket--bl {
    bottom: 0;
    left: 0;
    border-right: 0;
    border-top: 0;
  }
  .bracket--br {
    bottom: 0;
    right: 0;
    border-left: 0;
    border-top: 0;
  }
</style>
